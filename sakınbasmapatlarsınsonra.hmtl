<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Sakin Basma</title>
    <style>
        body { background: white; color: black; text-align: center; font-family: sans-serif; margin: 0; height: 100vh; overflow: hidden; display: block; }
        #status { position: fixed; top: 40px; left: 0; width: 100%; font-size: 1.3rem; font-weight: bold; z-index: 50; padding: 0 10px; }
        .btn { background: red; color: white; border: none; width: 100px; height: 100px; border-radius: 50%; font-weight: bold; font-size: 1.1rem; position: absolute; top: 60%; left: 50%; transform: translate(-50%, -50%); cursor: pointer; z-index: 10; touch-action: none; box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
        .scary { background: #1a0000 !important; color: red !important; }
        .scaryBtn { background: #600 !important; border: 3px solid red !important; box-shadow: 0 0 20px red; }
        #finalPic { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain; background: black; z-index: 100; }
        #kandirildin { display: none; position: fixed; top: 20px; width: 100%; color: red; font-size: 2.2rem; font-weight: bold; z-index: 110; text-shadow: 2px 2px 5px black; text-align: center; }
    </style>
</head>
<body id="mainBody">

    <div id="status">BUTONA BAS</div>
    <button id="runBtn" class="btn">BAS</button>
    <div id="kandirildin">HAHA KANDIRILDIN</div>
    
